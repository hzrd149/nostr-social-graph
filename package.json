{
  "name": "nostr-social-graph-repo",
  "private": true,
  "packageManager": "yarn@1.22.19",
  "workspaces": [
    "ts"
  ],
  "scripts": {
    "test": "yarn workspace nostr-social-graph test",
    "build": "yarn workspace nostr-social-graph build",
    "examples": "yarn workspace nostr-social-graph examples",
    "e2e": "yarn workspace nostr-social-graph e2e",
    "docs": "yarn workspace nostr-social-graph docs",
    "rust:test": "cargo test --manifest-path rust/Cargo.toml",
    "rust:fmt": "cargo fmt --manifest-path rust/Cargo.toml --all",
    "rust:clippy": "cargo clippy --manifest-path rust/Cargo.toml --all-targets -- -D warnings"
  }
}
